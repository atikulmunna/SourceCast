# ─── Public app origin ────────────────────────────────────────────────────────
# Use ":80" for first boot by public IP. Use "sourcecast.example.com" after DNS
# points to the EC2 public IP. Caddy will issue TLS automatically for a domain.
SOURCECAST_SITE_ADDRESS=:80
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_NAME=SourceCast

# ─── Backend runtime ──────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=14
JWT_ACCESS_SECRET=replace-with-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-at-least-32-characters

# ─── Managed services ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres?ssl=require&prepared_statement_cache_size=0
DIRECT_URL=postgresql+asyncpg://user:password@host:5432/postgres?ssl=require
REDIS_URL=rediss://default:password@host.upstash.io:6379
QDRANT_URL=https://your-qdrant-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_key

# ─── Queue and storage ────────────────────────────────────────────────────────
JOB_STALE_TIMEOUT_SECONDS=120
WORKER_MAX_JOBS=1
WORKER_POLL_DELAY_SECONDS=10
STORAGE_PROVIDER=local
AUDIO_STORAGE_POLICY=DELETE_AFTER_TRANSCRIPTION

# ─── AI / RAG ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=extractive
GROQ_API_KEY=your_groq_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_TIMEOUT_SECONDS=30
TRANSCRIPTION_PROVIDER=groq
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
TRANSCRIPTION_TIMEOUT_SECONDS=300
EMBEDDING_PROVIDER=hash
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2
DEFAULT_QDRANT_COLLECTION=source_chunks_v1_minilm_384
WHISPER_MODEL=tiny

# ─── YouTube fallback knobs ───────────────────────────────────────────────────
YOUTUBE_TRANSCRIPT_LANGUAGES=en,en-US,en-GB
YTDLP_COOKIES_FILE=
YTDLP_PROXY_URL=
YOUTUBE_TRANSCRIPT_PROXY_HTTP_URL=
YOUTUBE_TRANSCRIPT_PROXY_HTTPS_URL=
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
WEBSHARE_PROXY_LOCATIONS=
