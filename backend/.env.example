# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sourcecast:sourcecast_dev@localhost:5432/sourcecast
DIRECT_URL=

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production-access-secret
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret
ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=14

# ─── Infrastructure ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
WORKER_MAX_JOBS=1
WORKER_POLL_DELAY_SECONDS=10

# ─── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
AUDIO_STORAGE_POLICY=DELETE_AFTER_TRANSCRIPTION

# ─── AI / RAG ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_PROVIDER=extractive
LLM_MODEL=llama-3.1-8b-instant
LLM_TIMEOUT_SECONDS=30
TRANSCRIPTION_PROVIDER=local
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
TRANSCRIPTION_TIMEOUT_SECONDS=300
EMBEDDING_PROVIDER=sentence-transformers
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2
DEFAULT_QDRANT_COLLECTION=source_chunks_v1_minilm_384
WHISPER_MODEL=tiny

# ─── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true
